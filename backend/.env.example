# =============================================================================
# ENVIRONMENT: Example / Template
# This file IS safe to commit to version control.
# Copy this file → rename to .env → fill in real values.
# =============================================================================

# --- Server Config ---
PORT=5000
NODE_ENV=development
APP_URL=http://localhost:5000
API_ROOT=http://localhost:5000/api

# --- MongoDB Connection ---
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# --- JWT Auth Config ---
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# --- CORS Config ---
CORS_ORIGIN=http://localhost:5173
