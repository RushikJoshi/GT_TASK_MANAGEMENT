# =============================================================
# Project Management — Root .gitignore
# =============================================================

# ----- Node Modules -----
node_modules/
**/node_modules/

# ----- Environment Files (NEVER commit secrets) -----
.env
.env.local
.env.development
.env.production
# .env.example is SAFE to commit — keep it

# ----- Build Output -----
dist/
build/
.vite/

# ----- OS Files -----
.DS_Store
Thumbs.db
desktop.ini

# ----- Logs -----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----- Editor / IDE -----
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ----- Backend Specific -----
uploads/
*.pem
*.key
*.cert
